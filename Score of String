import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String s = sc.next();
        int score = 0;
        for(int i = 0; i < s.length() - 1; i++){
            score += Math.abs(s.charAt(i) - s.charAt(i + 1));
        }
        System.out.println(score);
    }
}
