import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int m = sc.nextInt();
        int totalPeople = 0;
        for(int i=0;i<n;i++){
            totalPeople += sc.nextInt();
        }
        int buses = (totalPeople + m - 1) / m;
        System.out.println(buses);
    }
}
